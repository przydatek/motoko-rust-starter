package root:ic-sig-verifier;

world ic-sig-verifier {
  export verify-canister-sig-mainnet: func(args-serialized: list<u8>) -> list<u8>;
  export verify-canister-sig: func(signature-cbor: list<u8>, message: list<u8>, public-key-der: list<u8>, ic-root-public-key-raw: list<u8>) -> bool;
  export verify-bls-sig: func(signature: list<u8>, message: list<u8>, public-key: list<u8>) -> bool;
}